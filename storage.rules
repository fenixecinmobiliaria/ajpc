rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Permitir leer cualquier archivo del Storage
    match /{allPaths=**} {
      allow read: if true;
      
      // Permitir subir, reemplazar o borrar solo si el usuario está autenticado
      allow write: if request.auth != null;
    }
  }
}